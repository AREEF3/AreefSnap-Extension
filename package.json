{
  "name": "a-snap",
  "displayName": "A-Snap",
  "description": "Beautiful code screenshots from VS Code",
  "version": "1.3.0",
  "publisher": "Areef",
  "icon": "Areef.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "a-snap.snap",
        "title": "A-Snap: Take Snap"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "a-snap.snap",
          "when": "editorHasSelection",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "browserify": "^17.0.1",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AREEF3/AreefSnap-Extension.git"
  },
  "license": "MIT",
  "dependencies": {
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1"
  }
}
